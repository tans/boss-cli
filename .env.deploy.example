# 部署凭据模板 — 复制为 .env.deploy 后填写
# 用法: cp .env.deploy.example .env.deploy
# 供 npm run deploy 读取（本地执行，不会上传到容器）

# Docker 镜像仓库（如阿里云 ACR）
DOCKER_REGISTRY=registry.cn-shanghai.aliyuncs.com/your-namespace
DOCKER_USERNAME=your-registry-username
DOCKER_PASSWORD=your-registry-password

# 镜像名称与标签（可选）
DOCKER_IMAGE_NAME=boss-cli-landing
# DEPLOY_TAG=latest

# 远程服务器 SSH（与 xhs-cli 同一台）
SSH_HOST=your.server.ip
SSH_PORT=22
SSH_USERNAME=root
SSH_PASSWORD=your-ssh-password

# 远程容器（可选）
DEPLOY_CONTAINER_NAME=boss-cli-landing
DEPLOY_PUBLISH_PORT=38522
# DEPLOY_CONTAINER_TZ=Asia/Shanghai

# 可选：跳过本地 build/push，仅 SSH 重启容器
# DEPLOY_SKIP_IMAGE_UPDATE=false

# 可选：docker build 时拉取最新基础镜像（网络不稳时可保持 false）
# DEPLOY_DOCKER_PULL_BASE=false

# 可选：构建平台，远程 VPS 通常为 linux/amd64
# DEPLOY_DOCKER_PLATFORM=linux/amd64
